<?xml version="1.0" encoding="utf-8"?>
<!--
  Mini player widget layout. Designed to be resizable from 4x1 (single row)
  to 4x2. The text container collapses gracefully when the widget is narrow.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_background"
    android:padding="10dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/widget_art_background"
        android:scaleType="centerCrop"
        android:contentDescription="@string/widget_open_app"
        android:src="@drawable/widget_default_art" />

    <LinearLayout
        android:id="@+id/widget_text_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="6dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/widget_nothing_playing" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#BBBBBB"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/widget_previous"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@drawable/widget_ic_previous"
        android:contentDescription="@string/widget_previous" />

    <ImageButton
        android:id="@+id/widget_play_pause"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@drawable/widget_ic_play"
        android:contentDescription="@string/widget_play_pause" />

    <ImageButton
        android:id="@+id/widget_next"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@drawable/widget_ic_next"
        android:contentDescription="@string/widget_next" />
</LinearLayout>
